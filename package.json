{
  "name": "mobile-preview-simulator",
  "publisher": "Prashantkhuva",
  "displayName": "Mobile Preview Simulator",
  "description": "Preview a local web app inside a polished mobile-sized webview.",
   "homepage": "https://github.com/Prashantkhuva/mobile-preview-simulator",
  "version": "3.2.4",
  "license": "MIT",
  "keywords": [
    "mobile",
    "preview",
    "simulator",
    "responsive",
    "device"
  ],
  "galleryBanner": {
    "color": "#0d0d0d",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mobile-preview-simulator.openPreview",
    "onView:mobile-preview-view"
  ],
  "main": "./dist/extension.js",
  "icon": "images/logo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mobile-preview-container",
          "title": "Preview",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "mobile-preview-container": [
        {
          "id": "mobile-preview-view",
          "name": "Mobile Preview",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Mobile Preview",
      "properties": {
        "mobilePreview.customDevices": {
          "type": "array",
          "default": [],
          "description": "Custom device presets shown in the device picker",
          "items": {
            "type": "object",
            "required": ["name", "width", "height"],
            "properties": {
              "name": { "type": "string", "description": "Device name (e.g. 'My Phone')" },
              "width": { "type": "number", "description": "Screen width in CSS pixels" },
              "height": { "type": "number", "description": "Screen height in CSS pixels" },
              "family": { "type": "string", "enum": ["phone", "tablet"], "default": "phone", "description": "Form factor" },
              "os": { "type": "string", "enum": ["ios", "android"], "default": "android", "description": "OS type" },
              "chrome": { "type": "string", "enum": ["notch", "island", "punch", "tablet"], "default": "punch", "description": "Camera cutout style" }
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "mobile-preview-simulator.openPreview",
        "title": "Open Preview",
        "shortTitle": "Preview",
        "icon": {
          "light": "images/icon.svg",
          "dark": "images/icon-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mobile-preview-simulator.openPreview",
          "group": "navigation",
          "icon": "images/icon.svg"
        }
      ]
    }
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/Prashantkhuva/mobile-preview-simulator.git"
}
}
